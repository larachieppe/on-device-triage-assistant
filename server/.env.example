ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5
PORT=8787
# Hard ceiling on /triage/fallback calls for the lifetime of the process —
# resets on redeploy/restart. Cost-abuse backstop for the public demo, not a
# real quota system.
GLOBAL_REQUEST_BUDGET=300
# Restrict CORS to the deployed web origin. Leave unset for local dev.
# ALLOWED_ORIGIN=https://on-device-triage-web.onrender.com
